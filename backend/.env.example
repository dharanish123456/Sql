# Database
DB_URL=jdbc:postgresql://localhost:5432/nexorcrm
DB_USERNAME=postgres
DB_PASSWORD=4658

# Bootstrap Super Admin
BOOTSTRAP_ENABLED=true
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@nexorcrm.com
BOOTSTRAP_SUPERADMIN_PASSWORD=Admin@1234

# JWT (minimum 32 characters, make it long and random)
JWT_SECRET=nexorcrm_jwt_super_secret_key_minimum_32_chars_long

# Frontend
FRONTEND_URL=http://localhost:5173

# Recovery (keep disabled in dev, enable only in emergency)
RECOVERY_ENABLED=false
RECOVERY_SECRET_TOKEN=nexorcrm_recovery_secret_token_xyz

# Refresh Cookie
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=Lax
REFRESH_COOKIE_MAX_AGE_DAYS=7
